{
  "name": "save47",
  "version": "1.0.0",
  "private": true,
  "description": "Save47 — Free, no-ads, no-login, privacy-first social media video and audio downloader.",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "apk:build": "bash apps/android/build.sh",
    "cli": "node apps/cli/dist/index.js"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "sharp": "^0.34.5",
    "typescript": "^5.4.0"
  }
}
