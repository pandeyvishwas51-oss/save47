# ============ BACKEND (apps/api/.env) ============

# Server
PORT=4000
NODE_ENV=development

# Redis (local dev)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis (production — Upstash)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# yt-dlp binary path (if not in PATH)
YTDLP_PATH=yt-dlp

# Admin panel — must be set to enable /admin/* and the web /admin page
ADMIN_TOKEN=change_me_to_a_long_random_string

# Cloudflare Turnstile
CF_TURNSTILE_SECRET_KEY=your_secret_key_here
# Get from: https://dash.cloudflare.com → Turnstile → Create widget

# ---- Billing (optional) ----
# Set these to enable Stripe-based plan upgrades. If unset, /billing/* routes
# return 503 and the API runs in fully-free mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_UNLIMITED=
SITE_URL=http://localhost:3000

# Cloudflare R2 (optional — for temp storage fallback)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=save47-temp
R2_PUBLIC_URL=

# Rate limiting
RATE_LIMIT_PROBE_PER_MINUTE=60
RATE_LIMIT_DOWNLOADS_PER_HOUR=15

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ============ FRONTEND (apps/web/.env.local) ============

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=your_site_key_here
# Get from: https://dash.cloudflare.com → Turnstile → Create widget

NEXT_PUBLIC_SITE_URL=http://localhost:3000
